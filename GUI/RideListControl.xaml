<UserControl x:Class="TransportationCompanyProject.GUI.RideListControl"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:TransportationCompanyProject.GUI"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <ListView Name="listView">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="ID"
        DisplayMemberBinding="{Binding Id}"
        Width="60"/>

                    <GridViewColumn Header="Driver"
        DisplayMemberBinding="{Binding Driver.Id}"
        Width="80"/>

                    <GridViewColumn Header="Request"
        DisplayMemberBinding="{Binding RideRequest.Id}"
        Width="80"/>

                    <GridViewColumn Header="Start Time"
        DisplayMemberBinding="{Binding StartTime}"
        Width="150"/>

                    <GridViewColumn Header="End Time"
        DisplayMemberBinding="{Binding EndTime}"
        Width="150"/>

                    <GridViewColumn Header="Status"
        DisplayMemberBinding="{Binding Status}"
        Width="100"/>

                    <GridViewColumn Header="Price"
        DisplayMemberBinding="{Binding Price}"
        Width="80"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>
