<UserControl x:Class="TransportationCompanyProject.GUI.VehicleListControl"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TransportationCompanyProject.GUI"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <ListView Name="listView">
            <ListView.View>
                <GridView >
                    <GridViewColumn Header="ID"
        DisplayMemberBinding="{Binding Id}"
        Width="60"/>

                    <GridViewColumn Header="Vehicle Type"
        DisplayMemberBinding="{Binding VehicleType}"
        Width="130"/>

                    <GridViewColumn Header="Capacity"
        DisplayMemberBinding="{Binding Capacity}"
        Width="90"/>

                    <GridViewColumn Header="License Plate"
        DisplayMemberBinding="{Binding LicensePlate}"
        Width="120"/>

                    <GridViewColumn Header="Status"
        DisplayMemberBinding="{Binding Status}"
        Width="100"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>
