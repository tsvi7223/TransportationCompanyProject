<Page x:Class="TransportationCompanyProject.GUI.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TransportationCompanyProject.GUI"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage">

    <Grid Background="#FF72D4B7">

        <Grid.RowDefinitions>

            <RowDefinition Height="2*"/>
            <RowDefinition/>

        </Grid.RowDefinitions>

        <Grid Grid.Row="0">


            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>

                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>

            </Grid.ColumnDefinitions>

            <TextBlock   Text=" User Name:" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30"/>
            <TextBlock   Text=" Password:" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30"/>

            <TextBox x:Name="UserNameTbox" Text="{Binding UserName}" FontSize="30" HorizontalContentAlignment="Left" VerticalContentAlignment="Center"  Grid.ColumnSpan="4" Grid.Column="2" Grid.Row="0" Margin="10,30,30,30"  Padding="10"/>
            <TextBox x:Name="PassTbox" Text="{Binding UserPassword}" FontSize="30" HorizontalContentAlignment="Left" VerticalContentAlignment="Center"  Grid.ColumnSpan="4" Grid.Column="2" Grid.Row="1" Margin="10,30,30,30"  Padding="10"/>

        </Grid>

        <Grid Grid.Row="1" >

            <Grid.ColumnDefinitions>

                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>

            </Grid.ColumnDefinitions>
            <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
                <Button   Height="40" Content="Register" FontSize="25"  Margin="60,20,0,0" VerticalAlignment="Top" Click="Button_Click"/>
                <Button   Height="50"  Content="Interested joining us?&#xD;&#xA;Click here!" Margin="60,75,0,0" VerticalAlignment="Top"  Background="{x:Null}" FontSize="16" Click="Button_Click_1"/>
                
            </Grid>

            <Button  Grid.Column="5"  Margin="0,20,30,75" Content="Login" FontSize="25" Click="login"/>
            <Button Grid.Column="4" Margin="0,20,30,75" x:Name="Manager_back_door" Content="Auto Fill Manager" Click="Manager_back_door_Click"/>
            <Button Grid.Column="3" Margin="0,20,30,75" x:Name="Driver_back_door" Content="Auto Fill Driver" Click="Driver_back_door_Click"/>
            <Button Grid.Column="2" Margin="0,20,30,75" x:Name="Customer_back_door" Content="Auto Fill Customer" Click="Customer_back_door_Click"/>
        </Grid>
    </Grid>
</Page>
