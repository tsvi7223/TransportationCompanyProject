<UserControl x:Class="TransportationCompanyProject.GUI.RideRequestListControl"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:TransportationCompanyProject.GUI"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <ListView Name="listView">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="ID"
        DisplayMemberBinding="{Binding Id}"
        Width="60"/>

                    <GridViewColumn Header="Customer"
        DisplayMemberBinding="{Binding Customer.Id}"
        Width="80"/>

                    <GridViewColumn Header="Pickup City"
        DisplayMemberBinding="{Binding PickupAddress.City.CityName}"
        Width="100"/>

                    <GridViewColumn Header="Pickup Street"
        DisplayMemberBinding="{Binding PickupAddress.Street.StreetName}"
        Width="100"/>

                    <GridViewColumn Header="Dest. City"
        DisplayMemberBinding="{Binding DestinationAddress.City.CityName}"
        Width="100"/>

                    <GridViewColumn Header="Dest. Street"
        DisplayMemberBinding="{Binding DestinationAddress.Street.StreetName}"
        Width="100"/>

                    <GridViewColumn Header="Request Time"
        DisplayMemberBinding="{Binding RequestTime}"
        Width="150"/>

                    <GridViewColumn Header="Scheduled Time"
        DisplayMemberBinding="{Binding ScheduledTime}"
        Width="150"/>

                    <GridViewColumn Header="Passengers"
        DisplayMemberBinding="{Binding NumberOfPassengers}"
        Width="90"/>

                    <GridViewColumn Header="Status"
        DisplayMemberBinding="{Binding Status}"
        Width="100"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>
