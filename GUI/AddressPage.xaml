<Page x:Class="TransportationCompanyProject.GUI.AddressPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TransportationCompanyProject.GUI"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddressPage">

    <Grid>
        <ListView Name="listViewAddresses">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Address ID" DisplayMemberBinding="{Binding Id}" />
                    <GridViewColumn Header="City" DisplayMemberBinding="{Binding City.Name}" />
                    <GridViewColumn Header="Street" DisplayMemberBinding="{Binding Street.Name}" />
                    <GridViewColumn Header="Building Number" DisplayMemberBinding="{Binding BuildingNumber}" />
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Page>
